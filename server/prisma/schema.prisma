generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                         String              @id @db.Uuid
  full_name                  String              @db.VarChar(100)
  username                   String              @unique @db.VarChar(50)
  avatar_url                 String?
  cover_photo_url            String?
  bio                        String?             @db.VarChar(150)
  phone                      String?             @db.VarChar(20)
  role                       String              @default("user")
  created_at                 DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?           @updatedAt @db.Timestamptz(6)
  posts                      Post[]
  post_likes                 PostLike[]
  post_comments              PostComment[]
  comment_likes              CommentLike[]
  post_saves                 PostSave[]
  follows_as_follower        Follow[]            @relation("follows_follower_idToprofiles")
  follows_as_following       Follow[]            @relation("follows_following_idToprofiles")
  bowls_last_updated         Bowl[]              @relation("bowls_last_updated_byToprofiles")
  bowl_status_logs           BowlStatusLog[]
  donations                  Donation[]
  announcements              Announcement[]
  products                   Product[]
  clinics                    Clinic[]
  events                     Event[]
  subscriptions              Subscription?
  badges                     Badge[]
  payment_methods            PaymentMethod[]
  event_registrations        EventRegistration[] @relation("event_registrations_user_idToprofiles")
  reviewed_registrations     EventRegistration[] @relation("event_registrations_reviewed_byToprofiles")

  @@map("profiles")
}

model Post {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String        @db.Uuid
  image_url     String
  content       String
  category      String?       @db.VarChar(50)
  is_priority   Boolean       @default(false)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?     @updatedAt @db.Timestamptz(6)
  user          Profile       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post_likes    PostLike[]
  post_comments PostComment[]
  post_saves    PostSave[]

  @@index([user_id])
  @@map("posts")
}

model PostLike {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String    @db.Uuid
  user_id    String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  post       Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user       Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([post_id, user_id])
  @@index([post_id])
  @@index([user_id])
  @@map("post_likes")
}

model PostComment {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id       String        @db.Uuid
  user_id       String        @db.Uuid
  text          String
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  post          Post          @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user          Profile       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  comment_likes CommentLike[]

  @@index([post_id])
  @@index([user_id])
  @@map("post_comments")
}

model CommentLike {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  comment_id String      @db.Uuid
  user_id    String      @db.Uuid
  created_at DateTime?   @default(now()) @db.Timestamptz(6)
  comment    PostComment @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user       Profile     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, user_id])
  @@index([comment_id])
  @@index([user_id])
  @@map("comment_likes")
}

model PostSave {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String    @db.Uuid
  user_id    String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  post       Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user       Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([post_id, user_id])
  @@index([post_id])
  @@index([user_id])
  @@map("post_saves")
}

model Follow {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  follower_id  String    @db.Uuid
  following_id String    @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  follower     Profile   @relation("follows_follower_idToprofiles", fields: [follower_id], references: [id], onDelete: Cascade)
  following    Profile   @relation("follows_following_idToprofiles", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@index([follower_id])
  @@index([following_id])
  @@map("follows")
}

model Bowl {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  qr_code           String          @unique @db.VarChar(20)
  status            String          @default("unknown")
  latitude          Decimal         @db.Decimal(10, 7)
  longitude         Decimal         @db.Decimal(10, 7)
  location_note     String?         @db.VarChar(200)
  last_updated_by   String?         @db.Uuid
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?       @updatedAt @db.Timestamptz(6)
  last_updated_user Profile?        @relation("bowls_last_updated_byToprofiles", fields: [last_updated_by], references: [id], onDelete: SetNull)
  bowl_status_logs  BowlStatusLog[]
  donations         Donation[]

  @@index([last_updated_by])
  @@map("bowls")
}

model BowlStatusLog {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bowl_id           String    @db.Uuid
  updated_by        String    @db.Uuid
  old_status        String?
  new_status        String
  old_latitude      Decimal?  @db.Decimal(10, 7)
  old_longitude     Decimal?  @db.Decimal(10, 7)
  new_latitude      Decimal?  @db.Decimal(10, 7)
  new_longitude     Decimal?  @db.Decimal(10, 7)
  new_location_note String?   @db.VarChar(200)
  source            String    @default("qr")
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  bowl              Bowl      @relation(fields: [bowl_id], references: [id], onDelete: Cascade)
  updater           Profile   @relation(fields: [updated_by], references: [id])

  @@index([bowl_id])
  @@index([updated_by])
  @@map("bowl_status_logs")
}

model Product {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String      @db.VarChar(150)
  description    String
  image_url      String
  animal_type    String
  price          Decimal     @db.Decimal(10, 2)
  nutrition_info String?
  is_active      Boolean     @default(true)
  created_by     String      @db.Uuid
  created_at     DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?   @updatedAt @db.Timestamptz(6)
  creator        Profile     @relation(fields: [created_by], references: [id])
  donations      Donation[]

  @@index([created_by])
  @@map("products")
}

model Clinic {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String      @db.VarChar(150)
  description          String
  image_url            String
  latitude             Decimal     @db.Decimal(10, 7)
  longitude            Decimal     @db.Decimal(10, 7)
  city                 String?     @db.VarChar(50)
  district             String?     @db.VarChar(50)
  location_description String?     @db.VarChar(200)
  is_active            Boolean     @default(true)
  created_by           String      @db.Uuid
  created_at           DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?   @updatedAt @db.Timestamptz(6)
  creator              Profile     @relation(fields: [created_by], references: [id])
  donations            Donation[]

  @@index([created_by])
  @@map("clinics")
}

model Donation {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  type             String
  amount           Decimal   @db.Decimal(10, 2)
  product_id       String?   @db.Uuid
  product_name     String?   @db.VarChar(100)
  product_quantity Int?
  clinic_id        String?   @db.Uuid
  clinic_name      String?   @db.VarChar(100)
  bowl_id          String?   @db.Uuid
  payment_method   String?   @db.VarChar(20)
  status           String    @default("completed")
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  user             Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product          Product?  @relation(fields: [product_id], references: [id])
  clinic           Clinic?   @relation(fields: [clinic_id], references: [id])
  bowl             Bowl?     @relation(fields: [bowl_id], references: [id])

  @@index([user_id])
  @@index([product_id])
  @@index([clinic_id])
  @@index([bowl_id])
  @@map("donations")
}

model PaymentMethod {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String    @db.Uuid
  brand           String    @db.VarChar(20)
  last4           String    @db.VarChar(4)
  cardholder_name String    @db.VarChar(120)
  expiry_month    Int
  expiry_year     Int
  card_type       String?   @db.VarChar(30)
  is_default      Boolean   @default(false)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @updatedAt @db.Timestamptz(6)
  user            Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("payment_methods")
}

model Announcement {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String              @db.Uuid
  category           String
  title              String              @db.VarChar(150)
  description        String
  latitude           Decimal             @db.Decimal(10, 7)
  longitude          Decimal             @db.Decimal(10, 7)
  address            String?
  city               String?             @db.VarChar(50)
  district           String?             @db.VarChar(50)
  location_note      String?             @db.VarChar(200)
  phone              String?             @db.VarChar(20)
  email              String?             @db.VarChar(150)
  status             String              @default("active")
  is_priority        Boolean             @default(false)
  report_type        String?             @db.VarChar(30)
  animal_type        String?             @db.VarChar(10)
  age                String?             @db.VarChar(15)
  gender             String?             @db.VarChar(10)
  neutered           String?             @db.VarChar(5)
  vaccination        String?             @db.VarChar(20)
  health_status      String?             @db.VarChar(10)
  environment        String?             @db.VarChar(10)
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?           @updatedAt @db.Timestamptz(6)
  user               Profile             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  announcement_images AnnouncementImage[]

  @@index([user_id])
  @@index([category])
  @@index([city])
  @@index([district])
  @@index([user_id, created_at])
  @@index([is_priority, created_at])
  @@map("announcements")
}

model AnnouncementImage {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcement_id String       @db.Uuid
  image_url       String
  display_order   Int          @default(0)
  created_at      DateTime?    @default(now()) @db.Timestamptz(6)
  announcement    Announcement @relation(fields: [announcement_id], references: [id], onDelete: Cascade)

  @@index([announcement_id])
  @@map("announcement_images")
}

model Event {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title               String              @db.VarChar(150)
  description         String
  image_url           String
  organizer           String              @db.VarChar(150)
  event_date          DateTime            @db.Timestamptz(6)
  latitude            Decimal             @db.Decimal(10, 7)
  longitude           Decimal             @db.Decimal(10, 7)
  address             String?
  city                String?             @db.VarChar(50)
  district            String?             @db.VarChar(50)
  location_note       String?             @db.VarChar(200)
  status              String              @default("upcoming")
  is_active           Boolean             @default(true)
  created_by          String              @db.Uuid
  created_at          DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?           @updatedAt @db.Timestamptz(6)
  creator             Profile             @relation(fields: [created_by], references: [id])
  event_registrations EventRegistration[]

  @@index([created_by])
  @@map("events")
}

model Subscription {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @unique @db.Uuid
  plan           String
  amount         Decimal   @db.Decimal(10, 2)
  start_date     DateTime  @default(now()) @db.Timestamptz(6)
  end_date       DateTime  @db.Timestamptz(6)
  payment_method String?   @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  user           Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Badge {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String    @db.Uuid
  type      String
  earned_at DateTime? @default(now()) @db.Timestamptz(6)
  user      Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, type])
  @@index([user_id])
  @@map("badges")
}

model EventRegistration {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id    String    @db.Uuid
  user_id     String    @db.Uuid
  email       String    @db.VarChar(150)
  status      String    @default("pending")
  reviewed_by String?   @db.Uuid
  reviewed_at DateTime? @db.Timestamptz(6)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  event       Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user        Profile   @relation("event_registrations_user_idToprofiles", fields: [user_id], references: [id], onDelete: Cascade)
  reviewer    Profile?  @relation("event_registrations_reviewed_byToprofiles", fields: [reviewed_by], references: [id])

  @@unique([event_id, user_id])
  @@index([event_id])
  @@index([user_id])
  @@index([reviewed_by])
  @@map("event_registrations")
}
